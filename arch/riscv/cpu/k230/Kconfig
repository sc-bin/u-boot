config RISCV_THEAD
	bool
	select ARCH_EARLY_INIT_R
	select SUPPORT_SPL
	imply CPU
	imply CPU_RISCV
	imply RISCV_TIMER
	imply RISCV_RDTIME
	imply CMD_CPU
	imply SPL_CPU
	imply SPL_OPENSBI
	imply SPL_LOAD_FIT


if RISCV_THEAD
config DDR_SIZE
	hex "DDR  Size"
	default 0x80000000 if LPDDR4_2667
	default 0x08000000 if SIPLP4_3200_WODT
	default 0x08000000 if SIPLP4_3200_WALLODT
	default 0x08000000 if SIPLP4_2667
	default 0x08000000 if SIPLP4_1600
	default 0x40000000 if CANMV_01STUDIO_LPDDR4_2667
	default 0x40000000 if CANMV_01STUDIO_LPDDR4_3200
	default 0x20000000
	help
	  Size of the DDR

config K230_BARE_DISP_LOGO
	bool "display k230 bare logo"
	select LAST_STAGE_INIT
	help
	  display k230 bare logo,bare-metal program

config K230_BARE_DISP_LOGO_PATH
	string "logo yuv nv12 pic path"
	default "board/canaan/k230-soc/logo/logo.yuv"
	depends on K230_BARE_DISP_LOGO
	help
	  logo pic,df sceen is 480*640,need yuv_nv12_640*480 pic;

config K230_BARE_DISP_LOGO_DF
	bool "df screen"
	depends on K230_BARE_DISP_LOGO
	help
	  df screen


endif
